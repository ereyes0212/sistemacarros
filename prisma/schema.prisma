generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  OTHER
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  SEMI_AUTOMATIC
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_NEGOTIATION
  CLOSED
  REJECTED
}

enum LeadType {
  CONTACT
  PURCHASE_REQUEST
  TEST_DRIVE
  FINANCING
}

model Permiso {
  id          String       @id @default(uuid())
  nombre      String       @unique
  descripcion String
  createAt    DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  activo      Boolean      @default(true)
  roles       RolPermiso[]
}

model RolPermiso {
  id        String   @id @default(uuid())
  rolId     String
  permisoId String
  createAt  DateTime @default(now())
  permiso   Permiso  @relation(fields: [permisoId], references: [id])
  rol       Rol      @relation(fields: [rolId], references: [id])

  @@unique([rolId, permisoId])
  @@index([permisoId], map: "RolPermiso_permisoId_fkey")
}

model Rol {
  id          String       @id @default(uuid())
  nombre      String       @unique
  descripcion String
  createAt    DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  activo      Boolean      @default(true)
  permisos    RolPermiso[]
  usuarios    Usuario[]
}

model Usuario {
  id                  String               @id @db.VarChar(36)
  usuario             String               @db.VarChar(50)
  contrasena          String               @db.LongText
  nombre              String?              @db.VarChar(100)
  fotoUrl             String?              @db.VarChar(512)
  direccion           String?              @db.VarChar(180)
  telefono            String?              @db.VarChar(30)
  ciudad              String?              @db.VarChar(100)
  DebeCambiarPassword Boolean?
  onboardingCompleted Boolean              @default(false)
  email               String               @unique
  createAt            DateTime             @default(now())
  updateAt            DateTime             @updatedAt
  rol_id              String               @db.VarChar(36)
  activo              Boolean              @default(true) @db.Bit(1)
  rol                 Rol                  @relation(fields: [rol_id], references: [id])
  PasswordResetToken  PasswordResetToken[]
  accounts            Account[]
  addresses           Address[]
  leads               VehicleLead[]        @relation("VehicleLeadBuyer")
  reviewedComments    VehicleComment[]     @relation("VehicleCommentReviewer")
  reviewedVehicles    Vehicle[]            @relation("VehicleReviewer")
  sessions            Session[]
  vehicleComments     VehicleComment[]     @relation("VehicleCommentAuthor")
  vehicles            Vehicle[]            @relation("VehicleSeller")
  vehicleWishlist     VehicleWishlist?

  @@index([rol_id], map: "IX_Usuarios_rol_id")
  @@map("Usuarios")
}

model VehicleBrand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  models      VehicleModel[]
  vehicles    Vehicle[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model VehicleModel {
  id        String       @id @default(uuid())
  brandId   String
  name      String
  slug      String
  brand     VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([brandId, slug])
  @@index([brandId])
}

model VehicleCategory {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String?
  parentId    String?
  parent      VehicleCategory?  @relation("VehicleCategoryHierarchy", fields: [parentId], references: [id])
  children    VehicleCategory[] @relation("VehicleCategoryHierarchy")
  vehicles    Vehicle[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Vehicle {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  description     String          @db.Text
  year            Int
  mileage         Int
  fuelType        FuelType
  transmission    TransmissionType
  price           Decimal         @db.Decimal(12, 2)
  country         String          @db.VarChar(100)
  city            String          @db.VarChar(100)
  vin             String?         @unique @db.VarChar(64)
  status          VehicleStatus   @default(AVAILABLE)
  listingStatus   ListingStatus   @default(PENDING_REVIEW)
  rejectionReason String?         @db.Text
  views           Int             @default(0)
  sellerId        String          @db.VarChar(36)
  reviewedById    String?         @db.VarChar(36)
  reviewedAt      DateTime?
  brandId         String
  modelId         String?
  categoryId      String
  brand           VehicleBrand    @relation(fields: [brandId], references: [id])
  category        VehicleCategory @relation(fields: [categoryId], references: [id])
  comments        VehicleComment[]
  images          VehicleImage[]
  leads           VehicleLead[]
  model           VehicleModel?   @relation(fields: [modelId], references: [id])
  seller          Usuario         @relation("VehicleSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  reviewedBy      Usuario?        @relation("VehicleReviewer", fields: [reviewedById], references: [id])
  versions        VehicleVersion[]
  wishlistItems   VehicleWishlistItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([listingStatus, status])
  @@index([brandId, modelId])
  @@index([categoryId])
  @@index([sellerId, listingStatus])
  @@index([country, city])
  @@index([price])
  @@index([year])
  @@index([mileage])
}

model VehicleImage {
  id        String   @id @default(uuid())
  vehicleId String
  url       String   @db.VarChar(1024)
  alt       String?
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, sortOrder])
}

model VehicleVersion {
  id           String            @id @default(uuid())
  vehicleId    String
  name         String
  trim         String?
  engine       String?
  transmission TransmissionType?
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([vehicleId])
}

model VehicleComment {
  id           String        @id @default(uuid())
  vehicleId    String
  userId       String        @db.VarChar(36)
  content      String        @db.Text
  status       CommentStatus @default(PENDING)
  reviewedById String?       @db.VarChar(36)
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user         Usuario       @relation("VehicleCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   Usuario?      @relation("VehicleCommentReviewer", fields: [reviewedById], references: [id])

  @@index([vehicleId, status])
  @@index([userId, status])
}

model VehicleWishlist {
  id        String                @id @default(uuid())
  userId    String                @unique @db.VarChar(36)
  user      Usuario               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     VehicleWishlistItem[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model VehicleWishlistItem {
  id         String          @id @default(uuid())
  wishlistId String
  vehicleId  String
  wishlist   VehicleWishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  vehicle    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([wishlistId, vehicleId])
  @@index([vehicleId])
}

model VehicleLead {
  id        String     @id @default(uuid())
  vehicleId String
  buyerId   String?    @db.VarChar(36)
  name      String     @db.VarChar(120)
  email     String     @db.VarChar(180)
  phone     String?    @db.VarChar(30)
  message   String?    @db.Text
  type      LeadType   @default(CONTACT)
  status    LeadStatus @default(NEW)
  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  buyer     Usuario?   @relation("VehicleLeadBuyer", fields: [buyerId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([vehicleId, status])
  @@index([buyerId, status])
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime
  createdAt DateTime @default(now())
  Usuario   Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "IX_PasswordResetToken_userId")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @db.VarChar(36)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String   @db.VarChar(36)
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @db.VarChar(36)
  label      String?
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
